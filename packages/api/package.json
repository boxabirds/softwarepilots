{
  "name": "@softwarepilots/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler d1 migrations apply DB --local --persist-to ../../.wrangler/state && wrangler dev --persist-to ../../.wrangler/state --inspector-port 9229",
    "deploy": "wrangler deploy",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --persist-to ../../.wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.0",
    "@types/bun": "^1.3.11",
    "wrangler": "^4.71.0"
  },
  "dependencies": {
    "@softwarepilots/shared": "workspace:*",
    "hono": "^4.7.0"
  }
}
